{
  "expo": {
    "name": "ŞarjBul",
    "slug": "sarjbul",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "sarjbul",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sarjbul.app",
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1117"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.sarjbul.app",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ŞarjBul, yakınındaki şarj istasyonlarını göstermek için konumuna ihtiyaç duyuyor.",
          "locationWhenInUsePermission": "ŞarjBul, yakınındaki şarj istasyonlarını göstermek için konumuna ihtiyaç duyuyor."
        }
      ]
    ]
  }
}
